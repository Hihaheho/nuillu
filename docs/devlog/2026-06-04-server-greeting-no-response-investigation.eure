    "body" = ````bash
# ログ中の peer 発話一覧
rg 'Peer says' .tmp/server/logs -n

# DB: reprioritize の priority 形状確認
sqlite3 .tmp/server/agent.db \
  "SELECT id, substr(trace_json,1,400) FROM llm_transcript_turns \
   WHERE owner_module='allocation-controller' AND trace_json LIKE '%reprioritize_modules%';"
