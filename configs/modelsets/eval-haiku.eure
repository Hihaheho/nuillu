name = "all haiku"

models {
  haiku {
    endpoint = "https://api.anthropic.com/v1"
    token-env = "ANTHROPIC_API_KEY"
    model = "claude-haiku-4-5"
  }
}

judge-model = "haiku"

cheap {
  model = "haiku"
  reasoning-effort = "low"
}

default {
  model = "haiku"
  reasoning-effort = "medium"
}

premium {
  model = "haiku"
  reasoning-effort = "high"
}
