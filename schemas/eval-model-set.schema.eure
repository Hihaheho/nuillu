/// Schema for configs/modelsets/**/*.eure files.

$schema = "https://eure.dev/v0.1.7/schemas/eure-schema.schema.eure"

name = `text`
name.$optional = true

compaction-input-token-threshold = `integer`
compaction-input-token-threshold.$optional = true

models = `$types.models-map`
models.$optional = true

judge-model = `text`
judge-model.$optional = true

cheap-model = `text`
cheap-model.$optional = true

default-model = `text`
default-model.$optional = true

premium-model = `text`
premium-model.$optional = true

judge = `$types.tier-binding`
judge.$optional = true

cheap = `$types.tier-binding`
cheap.$optional = true

default = `$types.tier-binding`
default.$optional = true

premium = `$types.tier-binding`
premium.$optional = true

embedding = `$types.embedding-role`
embedding.$optional = true

@ $types.models-map
$variant: map
key = `text`
value = `$types.model-definition`

@ $types.reasoning-effort
$variant: union
variants.none = { = "none", $variant => "literal" }
variants.minimal = { = "minimal", $variant => "literal" }
variants.low = { = "low", $variant => "literal" }
variants.medium = { = "medium", $variant => "literal" }
variants.high = { = "high", $variant => "literal" }
variants.xhigh = { = "xhigh", $variant => "literal" }

@ $types.model-definition
endpoint = `text`
endpoint.$optional = true
base-url = `text`
base-url.$optional = true
token = `text`
token.$optional = true
token-env = `text`
token-env.$optional = true
model = `text`
model.$optional = true
reasoning-effort = `$types.reasoning-effort`
reasoning-effort.$optional = true
temperature = `float`
temperature.$optional = true
top-p = `float`
top-p.$optional = true
top-k = `integer`
top-k.$optional = true
frequency-penalty = `float`
frequency-penalty.$optional = true
presence-penalty = `float`
presence-penalty.$optional = true
max-output-tokens = `integer`
max-output-tokens.$optional = true
seed = `integer`
seed.$optional = true
stop-sequences = [`text`]
stop-sequences.$optional = true
use-responses-api = `boolean`
use-responses-api.$optional = true
max-concurrent-llm-calls = `integer`
max-concurrent-llm-calls.$optional = true
compaction-input-token-threshold = `integer`
compaction-input-token-threshold.$optional = true

@ $types.tier-binding
model = `text`
reasoning-effort = `$types.reasoning-effort`
reasoning-effort.$optional = true
temperature = `float`
temperature.$optional = true
top-p = `float`
top-p.$optional = true
top-k = `integer`
top-k.$optional = true
frequency-penalty = `float`
frequency-penalty.$optional = true
presence-penalty = `float`
presence-penalty.$optional = true
max-output-tokens = `integer`
max-output-tokens.$optional = true
seed = `integer`
seed.$optional = true
stop-sequences = [`text`]
stop-sequences.$optional = true
compaction-input-token-threshold = `integer`
compaction-input-token-threshold.$optional = true

@ $types.embedding-role
endpoint = `text`
endpoint.$optional = true
base-url = `text`
base-url.$optional = true
token = `text`
token.$optional = true
token-env = `text`
token-env.$optional = true
model = `text`
model.$optional = true
dimensions = `integer`
dimensions.$optional = true
