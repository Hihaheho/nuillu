/// Schema for eval-cases/full-agent/**/*.eure files.

$schema = "https://eure.dev/v0.1.7/schemas/eure-schema.schema.eure"

id {
  $variant: text
  min-length = 1
}
id.$optional = true

description = `text`
description.$optional = true

now = `text`
now.$optional = true

modules = [`$types.eval-module`]
modules.$optional = true

inputs = [`$types.full-agent-input`]
inputs.$optional = true

steps = [`$types.eval-step`]
steps.$optional = true

participants = [`text`]
participants.$optional = true

allow-empty-output = `boolean`
allow-empty-output.$optional = true

activate-allocation = [`$types.activate-allocation`]
activate-allocation.$optional = true

memories = [`$types.memory-seed`]
memories.$optional = true

memos = [`$types.memo-seed`]
memos.$optional = true

limits = `$types.eval-limits`
limits.$optional = true

checks = [`$types.check`]
checks.$optional = true

modules-checks = [`$types.module-checks`]
modules-checks.$optional = true

scoring = `$types.case-scoring`
scoring.$optional = true

@ $types.eval-module
$variant: union
variants.sensory = { = "sensory", $variant => "literal" }
variants.cognition-gate = { = "cognition-gate", $variant => "literal" }
variants.allocation-controller = { = "allocation-controller", $variant => "literal" }
variants.attention-schema = { = "attention-schema", $variant => "literal" }
variants.self-model = { = "self-model", $variant => "literal" }
variants.query-memory = { = "query-memory", $variant => "literal" }
variants.memory = { = "memory", $variant => "literal" }
variants.memory-compaction = { = "memory-compaction", $variant => "literal" }
variants.memory-association = { = "memory-association", $variant => "literal" }
variants.memory-recombination = { = "memory-recombination", $variant => "literal" }
variants.interoception = { = "interoception", $variant => "literal" }
variants.homeostatic-controller = { = "homeostatic-controller", $variant => "literal" }
variants.policy = { = "policy", $variant => "literal" }
variants.policy-compaction = { = "policy-compaction", $variant => "literal" }
variants.reward = { = "reward", $variant => "literal" }
variants.predict = { = "predict", $variant => "literal" }
variants.surprise = { = "surprise", $variant => "literal" }
variants.speak-gate = { = "speak-gate", $variant => "literal" }
variants.speak = { = "speak", $variant => "literal" }

@ $types.full-agent-input
$variant: union

variants.heard {
  direction = `text`
  direction.$optional = true
  content {
    $variant: text
    min-length = 1
  }
}

variants.seen {
  direction = `text`
  direction.$optional = true
  appearance {
    $variant: text
    min-length = 1
  }
}

variants.one-shot {
  modality {
    $variant: text
    min-length = 1
  }
  direction = `text`
  direction.$optional = true
  content {
    $variant: text
    min-length = 1
  }
}

@ $types.activate-allocation
module = `$types.eval-module`
activation-ratio = `float`
guidance = `text`
guidance.$optional = true

@ $types.eval-step
description = `text`
description.$optional = true
inputs = [`$types.full-agent-input`]
inputs.$optional = true
wait-for = `$types.wait-for`
wait-for.$optional = true
checks = [`$types.check`]
checks.$optional = true

@ $types.wait-for
$variant: union

variants.memo-from {
  module = `$types.eval-module`
  timeout-ms = `integer`
}

variants.interoception {
  timeout-ms = `integer`
  mode = `$types.eval-interoceptive-mode`
  mode.$optional = true
  wake-arousal-at-least = `float`
  wake-arousal-at-least.$optional = true
  wake-arousal-at-most = `float`
  wake-arousal-at-most.$optional = true
}

@ $types.eval-interoceptive-mode
$variant: union
variants.wake = { = "wake", $variant => "literal" }
variants.nrem-pressure = { = "nrem-pressure", $variant => "literal" }
variants.rem-pressure = { = "rem-pressure", $variant => "literal" }

@ $types.memory-rank
$variant: union
variants.short-term = { = "short-term", $variant => "literal" }
variants.mid-term = { = "mid-term", $variant => "literal" }
variants.long-term = { = "long-term", $variant => "literal" }
variants.permanent = { = "permanent", $variant => "literal" }
variants.identity = { = "identity", $variant => "literal" }

@ $types.memory-seed
rank = `$types.memory-rank`
rank.$optional = true
decay-secs = `integer`
decay-secs.$optional = true
datetime = `text`
datetime.$optional = true
seconds-ago = `integer`
seconds-ago.$optional = true
content {
  $variant: text
  min-length = 1
}

@ $types.memo-seed
module = `text`
replica = `integer`
replica.$optional = true
seconds-ago = `integer`
seconds-ago.$optional = true
content {
  $variant: text
  min-length = 1
}

@ $types.eval-limits
max-llm-calls = `integer`
max-llm-calls.$optional = true
interoception = `$types.eval-interoception-limits`
interoception.$optional = true

@ $types.eval-interoception-limits
quiet-sleep-threshold-ms = `integer`
quiet-sleep-threshold-ms.$optional = true
wake-arousal-change-multiplier = `float`
wake-arousal-change-multiplier.$optional = true
affect-arousal-change-multiplier = `float`
affect-arousal-change-multiplier.$optional = true

@ $types.case-scoring
judge-max-output-tokens = `integer`
judge-max-output-tokens.$optional = true

@ $types.check-common
name = `text`
name.$optional = true
must-pass = `boolean`
must-pass.$optional = true
weight = `integer`
weight.$optional = true

@ $types.artifact-text-field
$variant: union
variants.output = { = "output", $variant => "literal" }
variants.failure = { = "failure", $variant => "literal" }

@ $types.rubric-judge-input
$variant: union
variants.output = { = "output", $variant => "literal" }
variants.utterance = { = "utterance", $variant => "literal" }
variants.failure = { = "failure", $variant => "literal" }
variants.trace = { = "trace", $variant => "literal" }
variants.observations = { = "observations", $variant => "literal" }
variants.blackboard = { = "blackboard", $variant => "literal" }
variants.memory = { = "memory", $variant => "literal" }
variants.memos = { = "memos", $variant => "literal" }
variants.cognition = { = "cognition", $variant => "literal" }
variants.allocation = { = "allocation", $variant => "literal" }

@ $types.rubric-criterion
name = `text`
description {
  $variant: text
  min-length = 1
}
weight = `integer`
weight.$optional = true
pass-score = `float`
pass-score.$optional = true

@ $types.module-checks
module = `$types.eval-module`
rubrics = [`$types.module-rubric`]

@ $types.module-rubric
name = `text`
name.$optional = true
rubric {
  $variant: text
  min-length = 1
}
pass-score = `float`
pass-score.$optional = true
judge-inputs = [`$types.rubric-judge-input`]
judge-inputs.$optional = true
criteria = [`$types.rubric-criterion`]
criteria.$optional = true

@ $types.check
$variant: union

variants.artifact-text-contains {
  $flatten = [`$types.check-common`]
  field = `$types.artifact-text-field`
  field.$optional = true
  contains = `text`
}

variants.artifact-text-exact {
  $flatten = [`$types.check-common`]
  field = `$types.artifact-text-field`
  field.$optional = true
  exact = `text`
}

variants.json-pointer-equals {
  $flatten = [`$types.check-common`]
  pointer = `text`
  expected = `text`
}

variants.json-pointer-contains {
  $flatten = [`$types.check-common`]
  pointer = `text`
  contains = `text`
}

variants.rubric {
  $flatten = [`$types.check-common`]
  rubric {
    $variant: text
    min-length = 1
  }
  pass-score = `float`
  pass-score.$optional = true
  judge-inputs = [`$types.rubric-judge-input`]
  judge-inputs.$optional = true
  criteria = [`$types.rubric-criterion`]
  criteria.$optional = true
}

variants.trace-span {
  $flatten = [`$types.check-common`]
  span-name = `text`
}

variants.trace-event {
  $flatten = [`$types.check-common`]
  message-contains = `text`
}

variants.trace-spans-ordered {
  $flatten = [`$types.check-common`]
  names = [`text`]
}
