/// Schema for eval-cases/full-agent/**/*.eure files.

$import = {
  common => "./eval-common.schema.eure"
}

$schema = "https://eure.dev/v0.1.7/schemas/eure-schema.schema.eure"

id {
  $variant: text
  min-length = 1
}
id.$optional = true

description = `text`
description.$optional = true

now = `text`
now.$optional = true

modules = [`$types.common.eval-module`]
modules.$optional = true

inputs = [`$types.full-agent-input`]
inputs.$optional = true

steps = [`$types.eval-step`]
steps.$optional = true

participants = [`text`]
participants.$optional = true

allow-empty-output = `boolean`
allow-empty-output.$optional = true

activate-allocation = [`$types.activate-allocation`]
activate-allocation.$optional = true

memories = [`$types.common.memory-seed`]
memories.$optional = true

memos = [`$types.common.memo-seed`]
memos.$optional = true

limits = `$types.eval-limits`
limits.$optional = true

checks = [`$types.common.check`]
checks.$optional = true

modules-checks = [`$types.module-checks`]
modules-checks.$optional = true

scoring = `$types.common.case-scoring`
scoring.$optional = true

@ $types.full-agent-input
$variant: union

variants.heard {
  direction = `text`
  direction.$optional = true
  content {
    $variant: text
    min-length = 1
  }
}

variants.seen {
  direction = `text`
  direction.$optional = true
  appearance {
    $variant: text
    min-length = 1
  }
}

variants.one-shot {
  modality {
    $variant: text
    min-length = 1
  }
  direction = `text`
  direction.$optional = true
  content {
    $variant: text
    min-length = 1
  }
}

@ $types.activate-allocation
module = `$types.common.eval-module`
activation-ratio = `float`

@ $types.eval-step
description = `text`
description.$optional = true
inputs = [`$types.full-agent-input`]
inputs.$optional = true
wait-for = `$types.wait-for`
checks = [`$types.common.check`]
checks.$optional = true

@ $types.wait-for
$variant: union
variants.some = `$types.wait-for-kind`
variants.none = { = null, $variant => "literal" }

@ $types.wait-for-kind
$variant: union

variants.memo-from {
  module = `$types.common.eval-module`
  timeout-ms = `integer`
}

variants.interoception {
  timeout-ms = `integer`
  mode = `$types.eval-interoceptive-mode`
  mode.$optional = true
  wake-arousal-at-least = `float`
  wake-arousal-at-least.$optional = true
  wake-arousal-at-most = `float`
  wake-arousal-at-most.$optional = true
}

@ $types.eval-interoceptive-mode
$variant: union
variants.wake = { = "wake", $variant => "literal" }
variants.nrem-pressure = { = "nrem-pressure", $variant => "literal" }
variants.rem-pressure = { = "rem-pressure", $variant => "literal" }

@ $types.eval-limits
$flatten = [`$types.common.eval-limits`]
interoception = `$types.eval-interoception-limits`
interoception.$optional = true

@ $types.eval-interoception-limits
quiet-sleep-threshold-ms = `integer`
quiet-sleep-threshold-ms.$optional = true
wake-arousal-change-multiplier = `float`
wake-arousal-change-multiplier.$optional = true
affect-arousal-change-multiplier = `float`
affect-arousal-change-multiplier.$optional = true

@ $types.module-checks
module = `$types.common.eval-module`
rubrics = [`$types.module-rubric`]

@ $types.module-rubric
name = `text`
name.$optional = true
rubric {
  $variant: text
  min-length = 1
}
pass-score = `float`
pass-score.$optional = true
judge-inputs = [`$types.common.rubric-judge-input`]
criteria = [`$types.common.rubric-criterion`]
criteria.$optional = true
