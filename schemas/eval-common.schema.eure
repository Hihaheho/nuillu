/// Shared types for eval case schemas.

$schema = "https://eure.dev/v0.1.7/schemas/eure-schema.schema.eure"

@ $types.eval-module
$variant: union
variants.sensory = { = "sensory", $variant => "literal" }
variants.cognition-gate = { = "cognition-gate", $variant => "literal" }
variants.allocation = { = "allocation", $variant => "literal" }
variants.attention-schema = { = "attention-schema", $variant => "literal" }
variants.self-model = { = "self-model", $variant => "literal" }
variants.query-memory = { = "query-memory", $variant => "literal" }
variants.memory = { = "memory", $variant => "literal" }
variants.memory-compaction = { = "memory-compaction", $variant => "literal" }
variants.memory-association = { = "memory-association", $variant => "literal" }
variants.memory-recombination = { = "memory-recombination", $variant => "literal" }
variants.interoception = { = "interoception", $variant => "literal" }
variants.homeostasis = { = "homeostasis", $variant => "literal" }
variants.policy = { = "policy", $variant => "literal" }
variants.policy-compaction = { = "policy-compaction", $variant => "literal" }
variants.reward = { = "reward", $variant => "literal" }
variants.predict = { = "predict", $variant => "literal" }
variants.surprise = { = "surprise", $variant => "literal" }
variants.speak = { = "speak", $variant => "literal" }

@ $types.memory-rank
$variant: union
variants.short-term = { = "short-term", $variant => "literal" }
variants.mid-term = { = "mid-term", $variant => "literal" }
variants.long-term = { = "long-term", $variant => "literal" }
variants.permanent = { = "permanent", $variant => "literal" }
variants.identity = { = "identity", $variant => "literal" }

@ $types.memory-seed
index = `text`
index.$optional = true
rank = `$types.memory-rank`
rank.$optional = true
decay-secs = `integer`
decay-secs.$optional = true
datetime = `text`
datetime.$optional = true
seconds-ago = `integer`
seconds-ago.$optional = true
content {
  $variant: text
  min-length = 1
}

@ $types.memory-link-seed
from-memory = `integer`
to-memory = `integer`
relation = `text`

@ $types.policy-rank
$variant: union
variants.tentative = { = "tentative", $variant => "literal" }
variants.provisional = { = "provisional", $variant => "literal" }
variants.established = { = "established", $variant => "literal" }
variants.habit = { = "habit", $variant => "literal" }
variants.core = { = "core", $variant => "literal" }

@ $types.policy-seed
index = `text`
rank = `$types.policy-rank`
rank.$optional = true
decay-secs = `integer`
decay-secs.$optional = true
trigger {
  $variant: text
  min-length = 1
}
behavior {
  $variant: text
  min-length = 1
}

@ $types.memo-seed
module = `text`
replica = `integer`
replica.$optional = true
seconds-ago = `integer`
seconds-ago.$optional = true
content {
  $variant: text
  min-length = 1
}

@ $types.cognition-log-seed
text {
  $variant: text
  min-length = 1
}
seconds-ago = `integer`
seconds-ago.$optional = true

@ $types.attention-seed
text {
  $variant: text
  min-length = 1
}
seconds-ago = `integer`
seconds-ago.$optional = true

@ $types.eval-limits
max-llm-calls = `integer`
max-llm-calls.$optional = true

@ $types.case-scoring
judge-max-output-tokens = `integer`
judge-max-output-tokens.$optional = true

@ $types.check-common
name = `text`
name.$optional = true
must-pass = `boolean`
must-pass.$optional = true
weight = `integer`
weight.$optional = true

@ $types.artifact-text-field
$variant: union
variants.output = { = "output", $variant => "literal" }
variants.failure = { = "failure", $variant => "literal" }

@ $types.rubric-judge-input
$variant: union
variants.output = { = "output", $variant => "literal" }
variants.utterance = { = "utterance", $variant => "literal" }
variants.failure = { = "failure", $variant => "literal" }
variants.trace = { = "trace", $variant => "literal" }
variants.memory = { = "memory", $variant => "literal" }
variants.memory-diff = { = "memory-diff", $variant => "literal" }
variants.memory-metadata = { = "memory-metadata", $variant => "literal" }
variants.policy-diff = { = "policy-diff", $variant => "literal" }
variants.policy-considerations = { = "policy-considerations", $variant => "literal" }
variants.memo-contents = { = "memo-contents", $variant => "literal" }
variants.cognition = { = "cognition", $variant => "literal" }
variants.cognition-entries = { = "cognition-entries", $variant => "literal" }
variants.tool-calls = { = "tool-calls", $variant => "literal" }
variants.tool-results = { = "tool-results", $variant => "literal" }

@ $types.rubric-criterion
name = `text`
description {
  $variant: text
  min-length = 1
}
weight = `integer`
weight.$optional = true
pass-score = `float`
pass-score.$optional = true

@ $types.check
$variant: union

variants.artifact-text-contains {
  $flatten = [`$types.check-common`]
  field = `$types.artifact-text-field`
  field.$optional = true
  contains = `text`
}

variants.artifact-text-exact {
  $flatten = [`$types.check-common`]
  field = `$types.artifact-text-field`
  field.$optional = true
  exact = `text`
}

variants.json-pointer-equals {
  $flatten = [`$types.check-common`]
  pointer = `text`
  expected = `text`
}

variants.json-pointer-contains {
  $flatten = [`$types.check-common`]
  pointer = `text`
  contains = `text`
}

variants.json-pointer-numeric-in-range {
  $flatten = [`$types.check-common`]
  pointer = `text`
  min = `float`
  min.$optional = true
  max = `float`
  max.$optional = true
}

variants.rubric {
  $flatten = [`$types.check-common`]
  rubric {
    $variant: text
    min-length = 1
  }
  pass-score = `float`
  pass-score.$optional = true
  judge-inputs = [`$types.rubric-judge-input`]
  criteria {
    $variant: array
    item = `$types.rubric-criterion`
    min-length = 1
  }
}

variants.trace-span {
  $flatten = [`$types.check-common`]
  span-name = `text`
}

variants.trace-event {
  $flatten = [`$types.check-common`]
  message-contains = `text`
}

variants.trace-tool-call {
  $flatten = [`$types.check-common`]
  tool-name = `text`
  args-json-contains = `text`
  args-json-contains.$optional = true
}

variants.trace-spans-ordered {
  $flatten = [`$types.check-common`]
  names = [`text`]
}
