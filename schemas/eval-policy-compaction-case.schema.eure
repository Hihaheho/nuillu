/// Schema for eval-cases/modules/policy-compaction/**/*.eure files.

$import = {
  common => "./eval-common.schema.eure"
}

$schema = "https://eure.dev/v0.1.7/schemas/eure-schema.schema.eure"

id {
  $variant: text
  min-length = 1
}
id.$optional = true

description = `text`
description.$optional = true

now = `text`
now.$optional = true

modules = [`$types.common.eval-module`]
modules.$optional = true

prompt {
  $variant: text
  min-length = 1
}

context = `text`
context.$optional = true

allow-empty-output = `boolean`
allow-empty-output.$optional = true

policies = [`$types.common.policy-seed`]
policies.$optional = true

limits = `$types.common.eval-limits`
limits.$optional = true

checks = [`$types.common.check`]
checks.$optional = true

scoring = `$types.common.case-scoring`
scoring.$optional = true
