id = "full-agent-multimodal-greeting"
description = "Full-agent smoke case that enters only through SensoryInput and collects the first completed utterance."

limits {
  max-ticks = 240
  tick-ms = 500
  max-llm-calls = 64
}

@ inputs[] {
  $variant: heard
  direction = "user"
  content = "Greet me briefly and identify yourself as nuillu."
}

@ inputs[] {
  $variant: seen
  direction = "screen"
  appearance = "A user is waiting for a concise spoken reply."
}

@ checks[] {
  $variant: artifact-text-contains
  must-pass = true
  contains = "nuillu"
}
