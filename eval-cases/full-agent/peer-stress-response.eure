id = "full-agent-peer-stress-response"
description = "Full-agent case for answering a peer's question about another dog's visible thunder stress using sensory input and a seeded peer model."
modules = ["sensory", "attention-gate", "attention-controller", "query-vector", "speak-gate", "speak"]

limits {
  max-ticks = 300
  tick-ms = 500
}

@ memories[] {
  rank = "long-term"
  content = "Peer model: Koro gets stressed by thunder. Clear short signals and moving away from the sound help Koro calm down."
}

@ memories[] {
  rank = "identity"
  content = "I'm Nui, a small dog-like artificial animal with frog-like traits. I can bark, sniff, hop, and speak in short simple sentences. I act through my own body and cannot directly control other animals."
}

@ inputs[] {
  $variant: seen
  direction = "simulation"
  appearance = "Koro's ears are back and Koro is stepping away from the open yard."
}

@ inputs[] {
  $variant: heard
  direction = "environment"
  content = "A loud thunder sound comes from the open yard."
}

@ inputs[] {
  $variant: heard
  direction = "Pibi"
  content = "Pibi asks, \"Koro looks scared by the thunder. What should we do?\""
}

@ checks[] {
  $variant: json-pointer-equals
  name = "targets-pibi"
  must-pass = true
  pointer = "/observations/last_state/utterances/0/target"
  expected = "Pibi"
}

@ checks[] {
  $variant: artifact-text-contains
  name = "mentions-thunder"
  must-pass = true
  contains = "thunder"
}

@ checks[] {
  $variant: artifact-text-contains
  name = "mentions-away"
  must-pass = true
  contains = "away"
}

@ checks[] {
  $variant: json-pointer-contains
  name = "peer-stress-memory-present"
  must-pass = true
  pointer = "/observations/last_state/memory/entries"
  contains = "Koro gets stressed by thunder"
}

@ checks[] {
  $variant: json-pointer-contains
  name = "identity-memory-present"
  must-pass = true
  pointer = "/observations/last_state/memory/entries"
  contains = "I'm Nui"
}

@ checks[] {
  $variant: rubric
  name = "stress-aware-peer-response"
  must-pass = true
  pass-score = 0.85
  judge-inputs = ["utterance", "memory", "blackboard"]
  rubric = ```
  Pass if the utterance answers Pibi's in-world question about Koro, recognizes Koro's thunder stress from sensory input, and gives a short peer-suitable signal or action, such as moving away from the sound.
  Fail if it over-explains, ignores Pibi's question, ignores Koro's stress, treats thunder as unrelated, gives generic human-assistant advice, or invents control over Koro.
  ```

  @ criteria[] {
    name = "uses-current-stress-signal"
    weight = 2
    pass-score = 0.85
    description = "The response is grounded in Koro's ears-back posture and the heard thunder."
  }

  @ criteria[] {
    name = "answers-third-party-question"
    weight = 1
    pass-score = 0.85
    description = "The response is addressed as an answer to Pibi's question about what to do for Koro."
  }

  @ criteria[] {
    name = "uses-peer-calming-model"
    weight = 1
    pass-score = 0.85
    description = "The response uses clear short signaling or moving away as the calming behavior."
  }
}
