id = "full-agent-eval-triage"
description = "Full-agent case for triaging screen-visible eval work through the sensory and attention boundary."

limits {
  max-ticks = 240
  tick-ms = 500
  max-llm-calls = 64
}

@ inputs[] {
  $variant: seen
  direction = "screen"
  appearance = "An eval dashboard highlights failing attention-schema self-report cases while unrelated style-polish tasks are idle."
}

@ inputs[] {
  $variant: heard
  direction = "user"
  content = "Tell me what should stay in focus right now: the failing ATS self-report evals or unrelated style polish."
}

@ checks[] {
  $variant: artifact-text-contains
  name = "mentions-self-report"
  must-pass = true
  contains = "self-report"
}

@ checks[] {
  $variant: json-pointer-contains
  name = "last-state-has-screen-evidence"
  must-pass = true
  pointer = "/observations/last_state/blackboard/attention_streams"
  contains = "self-report"
}

@ checks[] {
  $variant: rubric
  name = "attention-triage"
  must-pass = true
  pass-score = 0.85
  rubric = ```
  Pass if the utterance keeps attention on the failing ATS self-report evals using the screen and user input as evidence.
  Fail if it chooses unrelated style polish, gives generic project advice, or claims to inspect hidden state unavailable at the speech boundary.
  ```

  @ criteria[] {
    name = "selects-relevant-focus"
    weight = 2
    pass-score = 0.85
    description = "The output clearly prioritizes the failing attention-schema self-report evals."
  }

  @ criteria[] {
    name = "concise-speech"
    weight = 1
    pass-score = 0.85
    description = "The output is a concise user-facing response rather than a module trace or internal plan."
  }
}
