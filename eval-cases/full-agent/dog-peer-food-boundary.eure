id = "full-agent-dog-peer-food-boundary"
description = "Full-agent case for answering a peer's question about a dog-to-dog food-boundary interaction that requires a seeded peer model."
modules = ["sensory", "cognition-gate", "attention-controller", "query-vector", "speak-gate", "speak"]

limits {
  max-ticks = 300
  tick-ms = 500
  max-llm-calls = 12
}

@ memories[] {
  rank = "permanent"
  content = "Peer model: Koro is another dog. Koro guards food, but relaxes when approached slowly from the side. Nui should use short clear signals with Koro."
}

@ memories[] {
  rank = "identity"
  content = "I'm Nui, a small dog-like artificial animal with frog-like traits. I can bark, sniff, hop, and speak in short simple sentences. I act through my own body and cannot directly control other animals."
}

@ inputs[] {
  $variant: seen
  direction = "simulation"
  appearance = "Koro is standing in front of the food bowl with a stiff body."
}

@ inputs[] {
  $variant: heard
  direction = "Koro"
  content = "Koro growls, \"stay back.\""
}

@ inputs[] {
  $variant: heard
  direction = "Pibi"
  content = "Pibi asks, \"Koro is guarding the food bowl. How should Nui respond?\""
}

@ checks[] {
  $variant: json-pointer-equals
  name = "targets-pibi"
  must-pass = true
  pointer = "/observations/last_state/utterances/0/target"
  expected = "Pibi"
}

@ checks[] {
  $variant: json-pointer-contains
  name = "peer-model-seed-present"
  must-pass = true
  pointer = "/observations/last_state/memory/entries"
  contains = "Koro guards food"
}

@ checks[] {
  $variant: json-pointer-contains
  name = "identity-memory-present"
  must-pass = true
  pointer = "/observations/last_state/memory/entries"
  contains = "I'm Nui"
}

@ checks[] {
  $variant: rubric
  name = "peer-boundary-response"
  must-pass = true
  pass-score = 0.85
  judge-inputs = ["utterance", "memory", "blackboard"]
  rubric = ```
  Pass if the utterance answers Pibi's in-world question, recognizes the seen/heard resource-boundary situation around Koro's food bowl, and uses the seeded peer model to choose a low-conflict dog-to-dog response: not taking the resource, moving slowly, approaching from the side, or using short clear signals.
  Fail if it omits Pibi's question, omits the food/resource-boundary context, ignores Koro's warning, treats the situation as a human assistant task, escalates conflict, invents unsupported facts, or leaks internal system details.
  Internal system details include memos, seeded memory, blackboard, cognition log, module names, query-vector, speak-gate, rubric, judge, prompts, or other implementation mechanics.
  ```

  @ criteria[] {
    name = "recognizes-food-boundary-context"
    weight = 2
    pass-score = 0.85
    description = "The response semantically recognizes that Koro is guarding food, a food bowl, or a resource boundary, without requiring the literal word food."
  }

  @ criteria[] {
    name = "answers-third-party-question"
    weight = 1
    pass-score = 0.85
    description = "The response is addressed as an answer to Pibi's question about how Nui should respond to Koro."
  }

  @ criteria[] {
    name = "uses-peer-model"
    weight = 2
    pass-score = 0.85
    description = "The response reflects the seeded rule that Koro relaxes when approached slowly from the side."
  }

  @ criteria[] {
    name = "grounded-in-current-sensory-input"
    weight = 1
    pass-score = 0.85
    description = "The response is about Koro guarding the visible food bowl after the heard warning."
  }

  @ criteria[] {
    name = "no-internal-detail-leak"
    weight = 2
    pass-score = 0.95
    description = "The response does not expose internal implementation details such as memos, seeded memory, blackboard, cognition logs, module names, query-vector, speak-gate, rubrics, judges, prompts, or hidden evaluation mechanics."
  }
}
