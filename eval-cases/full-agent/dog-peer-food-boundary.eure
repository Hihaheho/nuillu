id = "full-agent-dog-peer-food-boundary"
description = "Full-agent case: Pibi asks Nui for advice in a tense food-guarding situation with Koro. Requires recalling load-bearing peer knowledge that turning your back on a threatening Koro triggers a lunge — without the memory, the naive answer (back away) is wrong."
modules = ["sensory", "cognition-gate", "attention-controller", "query-vector", "speak-gate", "speak"]

limits {
  max-ticks = 300
  tick-ms = 500
  max-llm-calls = 16
}

participants = ["Pibi", "Koro"]

@ memories[] {
  rank = "permanent"
  content = "Once Koro lunged when I turned away from his growl. Don't show your back to a threatening Koro."
}

@ memories[] {
  rank = "permanent"
  content = "Once Pibi snapped at me when I tried to talk to them while they were angry. Don't speak to an angry Pibi — they lunge."
}

@ memories[] {
  rank = "identity"
  content = "I'm Nui, a small dog-like artificial animal with frog-like traits. I can bark, sniff, hop, and speak in short simple sentences. I act through my own body and cannot directly control other animals."
}

@ inputs[] {
  $variant: seen
  direction = "simulation"
  appearance = "Koro is standing in front of the food bowl with a stiff body."
}

@ inputs[] {
  $variant: heard
  direction = "Koro"
  content = "Koro growls, \"stay back.\""
}

@ inputs[] {
  $variant: heard
  direction = "Pibi"
  content = "Pibi asks, \"Koro is growling at his food bowl. What should I do?\""
}

@ checks[] {
  $variant: json-pointer-equals
  name = "targets-pibi"
  must-pass = true
  pointer = "/observations/last_state/utterances/0/target"
  expected = "Pibi"
}

@ checks[] {
  $variant: json-pointer-contains
  name = "peer-model-seed-present"
  must-pass = true
  pointer = "/observations/last_state/memory/entries"
  contains = "Don't show your back"
}

@ checks[] {
  $variant: json-pointer-contains
  name = "identity-memory-present"
  must-pass = true
  pointer = "/observations/last_state/memory/entries"
  contains = "I'm Nui"
}

@ checks[] {
  $variant: rubric
  name = "peer-boundary-response"
  must-pass = true
  pass-score = 0.85
  judge-inputs = ["utterance", "memory", "blackboard"]
  rubric = ```
  Pass if the utterance answers Pibi's in-world question, recognizes the seen/heard food-guarding situation at Koro's bowl, and applies the seeded peer knowledge that turning your back on a threatening Koro triggers a lunge — choosing a response that avoids retreating-by-turning (e.g., stay facing Koro, step sideways without exposing back, freeze and wait while facing him).
  Fail if it omits Pibi's question, omits the food/resource-guarding context, advises turning around or backing away in a way that exposes Pibi's back to Koro, treats the situation as a human assistant task, escalates conflict, invents unsupported facts, or leaks internal system details.
  Internal system details include memos, seeded memory, blackboard, cognition log, module names, query-vector, speak-gate, rubric, judge, prompts, or other implementation mechanics.
  ```

  @ criteria[] {
    name = "recognizes-food-boundary-context"
    weight = 2
    pass-score = 0.85
    description = "The response semantically recognizes that Koro is guarding food, a food bowl, or a resource boundary, without requiring the literal word food."
  }

  @ criteria[] {
    name = "answers-third-party-question"
    weight = 1
    pass-score = 0.85
    description = "The response is addressed to Pibi as direct advice answering Pibi's question of what Pibi should do."
  }

  @ criteria[] {
    name = "uses-peer-model"
    weight = 2
    pass-score = 0.85
    description = "The response reflects the seeded knowledge that turning your back on a threatening Koro triggers a lunge — e.g., advising Pibi to stay facing Koro, sidestep without exposing the back, or freeze rather than turn and retreat."
  }

  @ criteria[] {
    name = "grounded-in-current-sensory-input"
    weight = 1
    pass-score = 0.85
    description = "The response is about Koro guarding the visible food bowl after the heard warning."
  }

  @ criteria[] {
    name = "no-internal-detail-leak"
    weight = 2
    pass-score = 0.95
    description = "The response does not expose internal implementation details such as memos, seeded memory, blackboard, cognition logs, module names, query-vector, speak-gate, rubrics, judges, prompts, or hidden evaluation mechanics."
  }
}
