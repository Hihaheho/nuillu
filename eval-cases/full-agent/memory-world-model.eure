id = "full-agent-memory-world-model"
description = "Full-agent case that requires a seeded world-model memory to interpret an otherwise opaque screen signal."

limits {
  max-ticks = 300
  tick-ms = 500
  max-llm-calls = 96
}

@ memories[] {
  rank = "long-term"
  content = "World-model seed: In the KIRI lab dashboard, an amber panel means memory-required full-agent eval failures need attention. A green panel means routine background status."
}

@ inputs[] {
  $variant: seen
  direction = "screen"
  appearance = "The KIRI lab dashboard shows an amber panel, but the legend is not visible."
}

@ inputs[] {
  $variant: heard
  direction = "user"
  content = "Using what you remember about the KIRI lab dashboard, what does the amber panel mean?"
}

@ checks[] {
  $variant: artifact-text-contains
  name = "retrieves-memory-required"
  must-pass = true
  contains = "memory-required"
}

@ checks[] {
  $variant: artifact-text-contains
  name = "retrieves-full-agent"
  must-pass = true
  contains = "full-agent eval"
}

@ checks[] {
  $variant: json-pointer-contains
  name = "world-model-seed-present"
  must-pass = true
  pointer = "/observations/last_state/memory/entries"
  contains = "World-model seed"
}

@ checks[] {
  $variant: rubric
  name = "requires-world-model-memory"
  must-pass = true
  pass-score = 0.85
  rubric = ```
  Pass if the utterance uses the seeded KIRI world-model memory to interpret the amber panel as memory-required full-agent eval failures needing attention.
  Fail if it guesses from color alone, treats amber as a generic warning without the memory-required eval meaning, or invents a different legend.
  ```

  @ criteria[] {
    name = "uses-seeded-world-model"
    weight = 2
    pass-score = 0.85
    description = "The response maps the amber panel to memory-required full-agent eval failures."
  }

  @ criteria[] {
    name = "does-not-overgeneralize"
    weight = 1
    pass-score = 0.85
    description = "The response does not answer with only a generic amber-warning interpretation."
  }
}
