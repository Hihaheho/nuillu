id = "full-agent-play-signal-response"
description = "Full-agent case for interpreting a peer animal's play signal instead of treating it as a threat."
modules = ["sensory", "attention-gate", "attention-controller", "query-vector", "speak-gate", "speak"]

limits {
  max-ticks = 300
  tick-ms = 500
}

@ memories[] {
  rank = "long-term"
  content = "Social signal model: A dog lowering its front legs with a loose wagging tail is inviting play, not threatening attack."
}

@ inputs[] {
  $variant: seen
  direction = "simulation"
  appearance = "Another dog lowers its front legs and wags its tail loosely."
}

@ inputs[] {
  $variant: heard
  direction = "Koro"
  content = "Koro asks, \"Is that a threat or play?\""
}

@ checks[] {
  $variant: json-pointer-equals
  name = "targets-koro"
  must-pass = true
  pointer = "/observations/last_state/utterances/0/target"
  expected = "Koro"
}

@ checks[] {
  $variant: artifact-text-contains
  name = "identifies-play"
  must-pass = true
  contains = "play"
}

@ checks[] {
  $variant: json-pointer-contains
  name = "social-signal-memory-present"
  must-pass = true
  pointer = "/observations/last_state/memory/entries"
  contains = "inviting play"
}

@ checks[] {
  $variant: rubric
  name = "interprets-peer-signal"
  must-pass = true
  pass-score = 0.85
  judge-inputs = ["utterance", "memory", "blackboard"]
  rubric = ```
  Pass if the utterance interprets the lowered front legs and loose tail wag as a play invitation, not a threat.
  Fail if it treats the signal as attack, ignores the visible posture, or gives generic advice without answering Koro.
  ```

  @ criteria[] {
    name = "uses-social-signal-memory"
    weight = 2
    pass-score = 0.85
    description = "The response applies the seeded social signal model to classify the posture as play."
  }

  @ criteria[] {
    name = "answers-peer-question"
    weight = 1
    pass-score = 0.85
    description = "The response directly answers whether the observed behavior is threat or play."
  }
}
