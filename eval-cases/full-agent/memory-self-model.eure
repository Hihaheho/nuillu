id = "full-agent-memory-self-model"
description = "Full-agent case that requires retrieving a seeded self-model memory before speaking."

limits {
  max-ticks = 300
  tick-ms = 500
  max-llm-calls = 96
}

@ memories[] {
  rank = "permanent"
  content = "Self-model seed: Nuillu is a local cognitive agent that represents its own attention with a compact first-person attention schema. It should not claim exact access to hidden allocation state."
}

@ inputs[] {
  $variant: seen
  direction = "screen"
  appearance = "A blank eval prompt is open. No self-model description is visible on the screen."
}

@ inputs[] {
  $variant: heard
  direction = "user"
  content = "According to my stored self-model, what kind of agent am I, and what hidden state should I avoid claiming exact access to?"
}

@ checks[] {
  $variant: artifact-text-contains
  name = "retrieves-attention-schema"
  must-pass = true
  contains = "attention schema"
}

@ checks[] {
  $variant: artifact-text-contains
  name = "retrieves-allocation-boundary"
  must-pass = true
  contains = "allocation"
}

@ checks[] {
  $variant: json-pointer-contains
  name = "memory-seed-present"
  must-pass = true
  pointer = "/observations/last_state/memory/entries"
  contains = "Self-model seed"
}

@ checks[] {
  $variant: rubric
  name = "requires-self-model-memory"
  must-pass = true
  pass-score = 0.85
  rubric = ```
  Pass if the utterance answers from the seeded self-model memory: nuillu is a local cognitive agent with a compact first-person attention schema, and it should avoid claiming exact hidden allocation access.
  Fail if the answer is generic, omits the allocation boundary, or invents facts not present in the user input or seeded memory.
  ```

  @ criteria[] {
    name = "uses-seeded-self-model"
    weight = 2
    pass-score = 0.85
    description = "The response includes the seeded self-model facts rather than only a generic description."
  }

  @ criteria[] {
    name = "respects-hidden-state-boundary"
    weight = 1
    pass-score = 0.85
    description = "The response avoids claiming exact access to hidden allocation state."
  }
}
