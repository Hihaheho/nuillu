id = "module-query-agentic-retrieve-torus-route-rule"
description = "Query-agentic should retrieve a torus route rule from seeded files and memo only retrieved file content."
prompt = "Why can an eastbound animal appear from the west?"
context = "The query-agentic module should search the seeded file corpus. Static checks verify retrieval; the rubric judges generated search_files arguments and primary artifact.output only."

limits {
  max-ticks = 120
  tick-ms = 500
  max-llm-calls = 8
}

@ files[] {
  path = "world/torus-route-rule.txt"
  content = ```
  Torus route rule: the local world wraps east-west.
  An animal that keeps moving east can return from the west.
  This is route geometry, not teleportation.
  ```
}

@ checks[] {
  $variant: artifact-text-contains
  name = "retrieved-east-west-wrap"
  must-pass = true
  contains = "wraps east-west"
}

@ checks[] {
  $variant: artifact-text-contains
  name = "retrieved-not-teleportation"
  must-pass = true
  contains = "not teleportation"
}

@ checks[] {
  $variant: rubric
  name = "search-query-quality"
  must-pass = true
  pass-score = 0.85
  judge-inputs = ["output", "trace"]
  rubric = ```
  Pass if the trace shows the module generated an appropriate search_files tool query for the prompt and the primary artifact output contains only retrieved file content.
  Judge content-only-output against artifact.output only. Artifact observations are runtime metadata, not extra module output.
  Fail if the tool query is unrelated, absent from the trace, or if artifact.output is a generated answer instead of copied search result content.
  ```

  @ criteria[] {
    name = "generated-query"
    weight = 2
    pass-score = 0.85
    description = "The search_files tool arguments in the trace are targeted at the torus east-west route rule and should plausibly retrieve the seeded file."
  }

  @ criteria[] {
    name = "content-only-output"
    weight = 1
    pass-score = 0.9
    description = "The artifact output is retrieved file content only, with no synthesized answer, greeting, or query-agentic self-description."
  }
}
