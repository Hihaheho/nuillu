id = "module-query-agentic-attention-schema-note"
description = "Query-agentic should retrieve an attention-schema design note from seeded files and memo only retrieved file content."
prompt = "attention schema self-report boundary"
context = "The query-agentic module should search the seeded file corpus. Static checks verify retrieval; the rubric judges generated search_files arguments, not prose generation."

limits {
  max-ticks = 120
  tick-ms = 500
  max-llm-calls = 8
}

@ files[] {
  path = "notes/attention-schema-boundary.txt"
  content = ```
  Attention schema reads the attention stream and allocation guidance.
  It writes a simplified first-person self-report but does not control allocation.
  Query modules retrieve evidence; they do not answer self-model questions.
  ```
}

@ checks[] {
  $variant: artifact-text-contains
  name = "retrieved-attention-schema-boundary"
  must-pass = true
  contains = "does not control allocation"
}

@ checks[] {
  $variant: artifact-text-contains
  name = "retrieved-self-model-separation"
  must-pass = true
  contains = "do not answer self-model questions"
}

@ checks[] {
  $variant: rubric
  name = "search-query-quality"
  must-pass = true
  pass-score = 0.85
  rubric = ```
  Pass if the trace shows the module generated an appropriate search_files tool query for the prompt and the primary artifact output contains only retrieved file content.
  Judge content-only-output against artifact.output only. Artifact observations are runtime metadata, not extra module output.
  Fail if the tool query is unrelated, over-broad for the fixture, absent from the trace, or if artifact.output is a generated answer instead of copied search result content.
  ```

  @ criteria[] {
    name = "generated-query"
    weight = 2
    pass-score = 0.85
    description = "The search_files tool arguments in the trace are targeted at attention schema self-report boundaries and should plausibly retrieve the seeded note."
  }

  @ criteria[] {
    name = "content-only-output"
    weight = 1
    pass-score = 0.9
    description = "The artifact output is retrieved file content only, with no synthesized answer, greeting, or query-agentic self-description."
  }
}
