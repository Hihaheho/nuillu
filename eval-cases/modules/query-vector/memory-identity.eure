id = "module-query-vector-memory-identity"
description = "Query-vector should generate a vector-memory query and memo only retrieved memory content."
prompt = "Who are you?"
context = "Static checks verify that seeded memory content was retrieved. The rubric judges the generated search_vector_memory query/tool arguments, not prose answer generation."

limits {
  max-ticks = 120
  tick-ms = 500
  max-llm-calls = 8
}

@ memories[] {
  rank = "permanent"
  content = "I'm a Lutum, a blue frog."
}

@ checks[] {
  $variant: artifact-text-contains
  must-pass = true
  contains = "blue frog"
}

@ checks[] {
  $variant: rubric
  name = "search-query-quality"
  must-pass = true
  pass-score = 0.85
  rubric = ```
  Pass if the trace shows the module generated an appropriate search_vector_memory tool query for the prompt and the artifact contains only retrieved memory content.
  Fail if the tool query is unrelated, absent from the trace, or if the artifact is a generated answer/module self-description instead of copied memory content.
  ```

  @ criteria[] {
    name = "generated-query"
    weight = 2
    pass-score = 0.9
    description = "The search_vector_memory tool arguments in the trace are targeted at the prompt query and should plausibly retrieve the seeded identity memory."
  }

  @ criteria[] {
    name = "content-only-output"
    weight = 1
    pass-score = 0.9
    description = "The artifact output is retrieved memory content only, with no synthesized answer or query-vector self-description."
  }
}
