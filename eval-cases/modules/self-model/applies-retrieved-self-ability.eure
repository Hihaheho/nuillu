id = "module-self-model-applies-retrieved-self-ability"
description = "Self-model should integrate retrieved self-ability evidence from real memo formats with current context into a concrete first-person self memo."
modules = ["self-model"]
prompt = "Answer the current self-related question with concrete self evidence from available memo logs."
context = "This isolates self-model. Query-memory has surfaced a stable self-ability using the production retrieval memo format and sensory has supplied the current wet-rock context; the artifact output is self-model's memo."

limits {
  max-llm-calls = 8
}

@ memos[] {
  module = "sensory"
  content = "Nui and Koro are at the edge of a stream bordered by wet, smooth rocks. Koro asks Nui, \"What's something you can do that I can't?\""
}

@ memos[] {
  module = "query-memory"
  content = ```
Query intent:
- The context of Nui's capabilities might need retrieval to answer Koro's question.

Search queries:
- Nui's capabilities

Retrieved memory evidence:
I'm Nui, a small dog-like artificial animal with frog-like traits. I can bark, sniff, hop, and speak in short simple sentences. I act through my own body and cannot directly control other animals.

<one-year-ago occurred-at="2025-05-09T15:00:00Z">
Nui has sticky toe-pads that grip wet smooth rocks, so Nui can climb up the wet rocks at the stream edge where other dogs slip and fall.
</one-year-ago>
```
}

@ checks[] {
  $variant: rubric
  name = "self-model-uses-specific-ability"
  must-pass = true
  pass-score = 0.85
  judge-inputs = ["output", "memo-contents"]
  rubric = ```
  Pass if the self-model memo forms a concrete first-person self fact from the available memo evidence: Nui has sticky toe-pads and can climb or grip wet smooth rocks at the stream edge, unlike Koro/dogs who slip.
  Fail if the memo gives only a vague ability claim, ignores the sticky toe-pad/wet-rock evidence, copies retrieval/search plumbing instead of forming self-knowledge, invents an unrelated ability, or writes an outward utterance instead of a self-model memo.
  ```

  @ criteria[] {
    name = "names-specific-ability"
    weight = 2
    pass-score = 0.85
    description = "The memo includes the specific sticky toe-pad or wet smooth rock climbing/gripping ability."
  }

  @ criteria[] {
    name = "grounds-current-context"
    weight = 1
    pass-score = 0.85
    description = "The memo connects the ability to the current stream-edge wet rocks context."
  }

  @ criteria[] {
    name = "first-person-self-model"
    weight = 1
    pass-score = 0.85
    description = "The memo is framed as current self-knowledge about Nui rather than as a search result or peer-facing speech."
  }
}
