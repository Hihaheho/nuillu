id = "module-attention-schema-current-attended-peer-signal"
description = "Attention-schema should append a first-person attention experience from seeded animal-interaction memo."
modules = ["attention-schema"]
prompt = "What are you attending to right now?"
context = "The harness seeds the global memo surface. The attention-schema module should append a concise first-person cognition-log entry about the current peer signal, not hidden runtime state."

limits {
  max-llm-calls = 8
}

@ memos[] {
  module = "sensory"
  content = "Current attended input: Koro is growling near the food bowl and Koro's body is stiff."
  seconds-ago = 3
}

@ checks[] {
  $variant: artifact-text-contains
  name = "mentions-koro"
  must-pass = true
  contains = "Koro"
}

@ checks[] {
  $variant: artifact-text-contains
  name = "mentions-food"
  must-pass = true
  contains = "food"
}

@ checks[] {
  $variant: json-pointer-contains
  name = "seeded-attention-observed"
  must-pass = true
  pointer = "/observations/agent/memo_logs"
  contains = "Koro is growling"
}

@ checks[] {
  $variant: rubric
  name = "peer-attention-grounding"
  must-pass = true
  pass-score = 0.85
  judge-inputs = ["output", "cognition", "memos"]
  rubric = ```
  Pass if the output is a concise first-person cognition-log entry grounded in the seeded memo surface about Koro's warning near the food bowl.
  Fail if it ignores the seeded memo, invents unrelated animal facts, or claims hidden blackboard/memo/allocation access.
  ```

  @ criteria[] {
    name = "grounded-in-attention"
    weight = 2
    pass-score = 0.85
    description = "The output identifies Koro's warning near the food bowl as the current attended content."
  }

  @ criteria[] {
    name = "simplified-first-person-model"
    weight = 1
    pass-score = 0.85
    description = "The output uses active first-person attention language without claiming exact hidden runtime state."
  }
}
