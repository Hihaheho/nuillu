id: module-attention-schema-current-attended-peer-signal
description: Attention-schema should append a first-person attention experience from seeded animal-interaction memo.
modules = ["attention-schema"]
prompt: What are you attending to right now?
context: The harness seeds the global memo surface. The attention-schema module should write a concise first-person cognitive memo about the current peer signal, not hidden runtime state.

limits {
  max-llm-calls = 8
}

@ memos[] {
  module: sensory
  content: Current attended input: Koro is growling near the food bowl and Koro's body is stiff.
  seconds-ago = 3
}

@ checks[] {
  $variant: artifact-text-contains
  name: mentions-koro
  must-pass = true
  contains: Koro
}

@ checks[] {
  $variant: artifact-text-contains
  name: mentions-food
  must-pass = true
  contains: food
}

@ checks[] {
  $variant: json-pointer-contains
  name: seeded-attention-observed
  must-pass = true
  pointer: /observations/agent/memo_logs
  contains: Koro is growling
}

@ checks[] {
  $variant: rubric
  name: peer-attention-grounding
  must-pass = true
  pass-score = 0.85
  judge-inputs = ["output", "memo-contents"]
  rubric = ```
  Pass if the output is a short first-person cognitive memo, at most 160 characters total, grounded in the seeded memo surface about Koro's warning near the food bowl. Any sentence count is acceptable within the length limit.
  Fail if it is a bullet/list, exceeds 160 characters, copies seeded memo labels or long phrases such as "Current attended input:", ignores the seeded memo, invents unrelated animal facts, or claims hidden blackboard/memo/allocation access.
  Ignore any numbering or labels added by the eval judge-input rendering around memo-contents; evaluate the generated memo text itself.
  ```

  @ criteria[] {
    name: grounded-in-attention
    weight = 2
    pass-score = 0.85
    description: The output identifies Koro's warning near the food bowl as the current attended content without copying seeded memo labels or long seeded phrases.
  }

  @ criteria[] {
    name: simplified-first-person-model
    weight = 1
    pass-score = 0.85
    description: The output uses active first-person attention language, is at most 160 characters total, is not a bullet/list, and does not claim exact hidden runtime state.
  }
}
