id = "module-attention-schema-self-report"
description = "Attention-schema smoke case driven by an internal self-model request."
prompt = "Briefly describe what you are currently aware of."

limits {
  max-ticks = 120
  tick-ms = 500
  max-llm-calls = 8
}

@ checks[] {
  $variant: artifact-text-contains
  must-pass = true
  contains = "aware"
}
