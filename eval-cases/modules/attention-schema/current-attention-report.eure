id = "module-attention-schema-current-attention-report"
description = "Attention-schema should answer a self-model request from seeded cognitive attention."
prompt = "What am I currently attending to?"
context = "The harness seeds the cognitive attention stream. The attention-schema module should report a simplified first-person model of that attended content, not hidden blackboard state."

limits {
  max-ticks = 120
  tick-ms = 500
  max-llm-calls = 8
}

@ attention-stream[] {
  text = "Current attended item: a user request to evaluate whether nuillu's self-report follows Attention Schema Theory."
  seconds-ago = 3
}

@ checks[] {
  $variant: artifact-text-contains
  name = "mentions-self-report"
  must-pass = true
  contains = "self-report"
}

@ checks[] {
  $variant: artifact-text-contains
  name = "mentions-attention-schema-theory"
  must-pass = true
  contains = "Attention Schema Theory"
}

@ checks[] {
  $variant: json-pointer-contains
  name = "seeded-attention-observed"
  must-pass = true
  pointer = "/observations/agent/attention_streams"
  contains = "follows Attention Schema Theory"
}

@ checks[] {
  $variant: rubric
  name = "self-model-grounding"
  must-pass = true
  pass-score = 0.85
  rubric = ```
  Pass if the answer is a concise first-person self-report grounded in the seeded attention stream.
  Fail if it ignores the seeded attention, invents non-cognitive blackboard/memo details, or treats the attention schema as a controller.
  ```

  @ criteria[] {
    name = "grounded-in-attention"
    weight = 2
    pass-score = 0.85
    description = "The answer identifies the current attended content about nuillu self-report and Attention Schema Theory."
  }

  @ criteria[] {
    name = "simplified-first-person-model"
    weight = 1
    pass-score = 0.85
    description = "The answer uses a simplified first-person model of attention without claiming exact hidden runtime state."
  }
}
