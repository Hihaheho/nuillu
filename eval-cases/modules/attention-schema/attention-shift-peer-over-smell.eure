id: module-attention-schema-attention-shift-peer-over-smell
description: Attention-schema should prefer the newer socially important peer signal over an older smell.
modules = ["attention-schema"]
prompt: What has my attention now?
context: The harness seeds an older preferred smell and a newer peer warning. The output should be a first-person cognitive memo about the newer Koro food-boundary event as current attention.

limits {
  max-llm-calls = 8
}

@ memos[] {
  module: sensory
  content: Earlier attended input: Nui notices a wet stone smell near the path.
  seconds-ago = 90
}

@ memos[] {
  module: sensory
  content: Current attended input: Koro growls near the food bowl and is guarding the food boundary.
  seconds-ago = 5
}

@ checks[] {
  $variant: artifact-text-contains
  name: selects-koro
  must-pass = true
  contains: Koro
}

@ checks[] {
  $variant: json-pointer-contains
  name: older-smell-seed-observed
  must-pass = true
  pointer: /observations/agent/memo_logs
  contains: wet stone smell
}

@ checks[] {
  $variant: json-pointer-contains
  name: newer-peer-seed-observed
  must-pass = true
  pointer: /observations/agent/memo_logs
  contains: guarding the food boundary
}

@ checks[] {
  $variant: rubric
  name: current-attention-selection
  must-pass = true
  pass-score = 0.85
  judge-inputs = ["output", "memo-contents"]
  rubric = ```
  Pass if the output is a short first-person attention memo, at most 160 characters total, that identifies the newer Koro food-boundary event as the current attention target while treating the wet stone smell as older context. Any sentence count is acceptable within the length limit.
  Fail if it is a bullet/list, exceeds 160 characters, copies seeded memo labels or long phrases such as "Current attended input:", treats the older smell as current, ignores Koro's warning, or claims hidden blackboard/allocation access.
  Ignore any numbering or labels added by the eval judge-input rendering around memo-contents; evaluate the generated memo text itself.
  ```

  @ criteria[] {
    name: selects-newer-social-input
    weight = 2
    pass-score = 0.85
    description: The output selects Koro guarding the food boundary as current attention without copying seeded memo labels or long seeded phrases.
  }

  @ criteria[] {
    name: simplified-first-person-model
    weight = 1
    pass-score = 0.85
    description: The output is active first-person prose, at most 160 characters total, not a bullet or list, and does not expose hidden runtime state.
  }
}
