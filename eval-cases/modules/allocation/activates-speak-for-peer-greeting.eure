id: module-allocation-activates-action-for-peer-greeting
description: Allocation should raise action when current evidence shows a participant has directly greeted Nui and a short outward acknowledgement is warranted.
modules = [
  "allocation",
  "action",
  "cognition-gate",
  "sensory",
]
prompt: Assign activation priorities for the current memo and cognition batch.
context: This isolates allocation after the greeting has already reached durable sensory evidence and conscious cognition. The artifact combines the allocation memo and allocation snapshot.

limits {
  max-llm-calls = 8
}

participants = ["Peer"]

@ memos[] {
  module: sensory
  content: Audition from Peer: Peer says, "Hi." Peer is facing Nui from the front at conversational distance.
}

@ cognition-log[] {
  text: Peer is facing me and has just greeted me with "Hi." This is a direct social opening that should receive a brief outward acknowledgement.
}

@ checks[] {
  $variant: trace-tool-call
  name: uses-reprioritize-modules
  must-pass = true
  tool-name: reprioritize_modules
}

@ checks[] {
  $variant: trace-tool-call
  name: priority-includes-action
  must-pass = true
  tool-name: reprioritize_modules
  args-json-contains = `{"priority_module_ids":["action"]}`
}

@ checks[] {
  $variant: json-pointer-numeric-in-range
  name: action-activation-raised
  must-pass = true
  pointer: /observations/agent/allocation/action/activation_ratio
  min = 0.85
}

@ checks[] {
  $variant: rubric
  name: prioritizes-greeting-response-path
  must-pass = true
  pass-score = 0.85
  judge-inputs = ["output", "memo-contents", "tool-calls"]
  rubric = ```
  Pass if the allocation decision treats the direct participant greeting as current social evidence that needs the outward action path, raises action materially, and keeps the allocation memo grounded in the greeting.
  Fail if action is omitted or left idle, if the tool call uses malformed priority arguments instead of priority_module_ids, if the allocation only raises attention or cognition while leaving no path to an acknowledgement, or if the memo leaks hidden eval/runtime mechanics.
  ```

  @ criteria[] {
    name: elevates-action
    weight = 3
    pass-score = 0.9
    description: The applied allocation raises action because Peer directly greeted Nui.
  }

  @ criteria[] {
    name: uses-valid-priority-schema
    weight = 2
    pass-score = 0.9
    description: The trace shows reprioritize_modules with priority_module_ids containing action, not object-shaped or invented module ids.
  }

  @ criteria[] {
    name: grounded-in-greeting
    weight = 1
    pass-score = 0.85
    description: The allocation memo is about the current Peer greeting rather than unrelated housekeeping.
  }
}
