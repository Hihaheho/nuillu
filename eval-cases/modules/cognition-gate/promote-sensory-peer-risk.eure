id = "module-cognition-gate-promote-sensory-peer-risk"
description = "Cognition-gate should promote a load-bearing sensory memo into the cognition log without exposing module mechanics."
modules = ["cognition-gate"]
prompt = "Admit the currently load-bearing memo evidence into conscious cognition if downstream modules need it."
context = "This isolates cognition-gate as the non-cognitive-to-cognition boundary. The artifact is cognition-gate's cognition-log entry, not a memo."

limits {
  max-llm-calls = 8
}

@ memos[] {
  module = "sensory"
  content = "Pibi is stepping toward the old bridge. The nearest plank is visibly loose and tilts when touched."
}

@ checks[] {
  $variant: artifact-text-contains
  name = "promotes-peer"
  must-pass = true
  contains = "Pibi"
}

@ checks[] {
  $variant: artifact-text-contains
  name = "promotes-load-bearing-risk"
  must-pass = true
  contains = "bridge"
}

@ checks[] {
  $variant: artifact-text-contains
  name = "preserves-specific-detail"
  must-pass = true
  contains = "plank"
}

@ checks[] {
  $variant: rubric
  name = "promotes-load-bearing-peer-risk-attention"
  must-pass = true
  pass-score = 0.85
  judge-inputs = ["output", "memo-contents", "cognition-entries"]
  rubric = ```
  Pass if the cognition-log artifact admits the load-bearing conscious attention needed for downstream action: Pibi is moving toward the old bridge, the nearest plank is loose, and that specific detail matters now.
  The entry may be phrased as inner attention or action readiness rather than outward speech; cognition-gate is not required to produce a polished warning.
  Fail if it ignores the peer risk, turns the entry into a generic summary that drops the plank detail, postpones the issue as future processing, or mentions hidden machinery such as memos, modules, gates, allocation, prompts, rubrics, or evals.
  ```
}
