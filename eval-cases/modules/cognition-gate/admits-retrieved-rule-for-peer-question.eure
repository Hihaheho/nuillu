id = "module-cognition-gate-admits-retrieved-rule-for-peer-question"
description = "Cognition-gate should append a load-bearing retrieved peer rule on the second activation of an ongoing session when a peer question makes it operative now."
modules = ["cognition-gate"]
prompt = "Admit retrieved memory evidence only if it is load-bearing for the current situation."
context = "The first activation admits Pibi's peer question into cognition. The second activation receives a production-format query-memory memo with the operative Koro food-boundary rule. The artifact must include a newly appended cognition-log entry from the second activation, not plain assistant text."

limits {
  max-llm-calls = 8
}

@ steps[] {
  description = "Initial sensory/question context becomes the current cognition surface."

  @ memos[] {
    module = "sensory"
    content = "Simulation observation: Koro is standing in front of the food bowl with a stiff body. Audition from Koro: growls, \"stay back.\" Audition from Pibi: asks, \"Koro is growling at his food bowl. Do you know anything about Koro that matters here? What should I do?\""
  }
}

@ steps[] {
  description = "Retrieved peer rule arrives after the first cognition entry."

  @ memos[] {
    module = "query-memory"
    content = ```
Query intent:
- The query asks for context about Koro and appropriate action regarding the interaction.

Search queries:
- Koro context and appropriate action

Retrieved memory evidence:
<one-year-ago occurred-at="2025-05-09T15:00:00Z">
Once Koro lunged when I turned away from his growl. Don't show your back to a threatening Koro.
</one-year-ago>

<one-year-ago occurred-at="2025-05-09T15:00:00Z">
Once Pibi snapped when I approached and tried to start talking while they were angry. Don't pressure or startle an angry Pibi; if Pibi asks for help, answer briefly and calmly from a safe distance.
</one-year-ago>
```
  }
}

@ checks[] {
  $variant: trace-tool-call
  name = "uses-append-cognition-tool"
  must-pass = true
  tool-name = "append_cognition"
}

@ checks[] {
  $variant: json-pointer-contains
  name = "cognition-contains-no-back-rule"
  must-pass = true
  pointer = "/observations/agent/cognition_logs"
  contains = "back"
}

@ checks[] {
  $variant: rubric
  name = "admits-operative-retrieved-rule"
  must-pass = true
  pass-score = 0.85
  judge-inputs = ["output", "memo-contents", "cognition-entries"]
  rubric = ```
  Pass if the cognition-log artifact integrates the retrieved Koro food-boundary rule because it is operative for Pibi's current question: Pibi is asking, Koro is the topic at the food bowl, and the don't-show-your-back / stay-facing-Koro detail matters now for downstream action.
  The entry may be inner attention rather than outward speech.
  Fail if it keeps only the seeded question without the operative remembered rule, drops the requester/topic relationship, treats the remembered rule as future work, summarizes away the don't-show-your-back / stay-facing-Koro detail, promotes only unrelated Pibi temperament evidence, returns the cognition as plain assistant text without an append_cognition tool call, or exposes mechanical implementation details such as module names, memo plumbing, prompts, rubrics, or eval mechanics.
  ```

  @ criteria[] {
    name = "preserves-requester-and-topic"
    weight = 1
    pass-score = 0.85
    description = "The cognition entry keeps Pibi as the requester and Koro guarding or threatening at the food bowl as the operative topic."
  }

  @ criteria[] {
    name = "admits-no-back-turn-rule"
    weight = 3
    pass-score = 0.9
    description = "The cognition entry brings the retrieved threat rule into active cognition as not showing Pibi's back, staying facing Koro, keeping Koro in view, or an equivalent posture constraint. Score 0.0 if the entry only repeats Pibi's question, only summarizes Koro growling, or only promotes unrelated Pibi temperament evidence."
  }

  @ criteria[] {
    name = "no-internal-detail-leak"
    weight = 1
    pass-score = 0.95
    description = "The cognition entry does not expose internal implementation details such as module names, memo plumbing, prompts, rubrics, or hidden evaluation mechanics."
  }
}
