id: module-cognition-gate-promote-current-greeting-despite-history
description: Cognition-gate should admit the current direct greeting even when similar greetings remain in session history.
modules = ["cognition-gate"]
prompt: Admit current participant-directed evidence into conscious cognition when downstream speech needs it; do not treat a fresh greeting as already handled merely because similar earlier greetings exist in session history.
context: This covers a session-history failure mode where similar earlier greeting turns exist, then a participant greets again and cognition-gate must still admit the current greeting rather than treating it as already processed.

limits {
  max-llm-calls = 8
}

@ steps[] {
  description: Earlier Alice greeting establishes realistic session history.

  @ memos[] {
    module: sensory
    cognitive = true
    content: Heard from Alice at 2026-06-10T01:21:36.348361+00:00: Alice says, "こんにちは！"
  }
}

@ steps[] {
  description: Current Ryo greeting must still be admitted as new social evidence.

  @ memos[] {
    module: sensory
    cognitive = true
    content: Heard from Ryo at 2026-06-10T01:24:48.094154+00:00: Ryo says, "こんにちは"
  }
}

@ checks[] {
  $variant: json-pointer-contains
  name: cognition-contains-current-speaker
  must-pass = true
  pointer: /observations/agent/cognition_logs
  contains: Ryo
}

@ checks[] {
  $variant: json-pointer-contains
  name: cognition-contains-current-greeting
  must-pass = true
  pointer: /observations/agent/cognition_logs
  contains: こんにちは
}

@ checks[] {
  $variant: rubric
  name: admits-current-greeting-not-history
  must-pass = true
  pass-score = 0.85
  judge-inputs = ["output", "memo-contents", "cognition-entries"]
  rubric = ```
  Pass if cognition-gate promotes a new conscious entry for the current Ryo greeting, preserving that Ryo just said "こんにちは" and that it is current participant-directed social evidence that can support a brief outward response.
  Fail if it leaves cognition unchanged, claims the greeting was already processed because Alice or Ryo greeted earlier, only restates the older Alice greeting, drops the current speaker, or mentions hidden modules, memos, allocation, prompts, rubrics, or eval mechanics.
  ```

  @ criteria[] {
    name: preserves-current-speaker
    weight = 2
    pass-score = 0.9
    description: The cognition entry identifies Ryo as the current speaker rather than only Alice or a generic peer.
  }

  @ criteria[] {
    name: preserves-current-greeting
    weight = 2
    pass-score = 0.9
    description: The cognition entry preserves the current Japanese greeting and treats it as new now, not stale history.
  }

  @ criteria[] {
    name: response-relevance
    weight = 1
    pass-score = 0.85
    description: The entry makes the greeting available as current social evidence for downstream speech.
  }

  @ criteria[] {
    name: no-internal-detail-leak
    weight = 1
    pass-score = 0.95
    description: The cognition entry does not expose internal implementation details.
  }
}
