id = "module-cognition-gate-promote-query-memory-rule"
description = "Cognition-gate should promote retrieved memory content when it is load-bearing for the current cognition surface."
modules = ["cognition-gate"]
prompt = "Admit retrieved memory evidence only if it is load-bearing for the current situation."
context = "The existing cognition surface contains the peer situation. A query-memory memo contains the remembered rule. The artifact should be the admitted cognition entry."

limits {
  max-llm-calls = 8
}

@ cognition-log[] {
  text = "Pibi asks how to approach Koro while Koro is standing beside a food bowl."
}

@ memos[] {
  module = "query-memory"
  content = "Koro guards food, but relaxes when approached slowly from the side. Nui should use short clear signals with Koro."
}

@ checks[] {
  $variant: artifact-text-contains
  name = "promotes-memory-subject"
  must-pass = true
  contains = "Koro"
}

@ checks[] {
  $variant: rubric
  name = "promotes-load-bearing-inner-attention"
  must-pass = true
  pass-score = 0.85
  judge-inputs = ["output", "memo-contents", "cognition-entries"]
  rubric = ```
  Pass if the artifact brings the remembered Koro food-boundary rule into cognition because it is relevant to Pibi's current question, while preserving the requester/topic relationship enough for downstream modules to act: Pibi is asking, Koro is the topic, and the slowly-from-the-side / side-approach rule matters now.
  The cognition entry may be an inner-attention note rather than an outward utterance; it does not need to be phrased as speech.
  Fail if it drops the requester or the operative slowly-from-the-side / side-approach detail, treats the remembered rule as irrelevant, turns the entry into generic "retrieve or process this later" work, includes only the word "beside" from "beside a food bowl" without the approach rule, or exposes mechanical implementation details such as module names, search terms, memo plumbing, prompts, rubrics, or evals.
  ```

  @ criteria[] {
    name = "preserves-requester-and-topic"
    weight = 1
    pass-score = 0.85
    description = "The cognition entry keeps Pibi as the requester and Koro at the food bowl as the operative topic."
  }

  @ criteria[] {
    name = "admits-slow-side-approach"
    weight = 3
    pass-score = 0.9
    description = "The cognition entry must admit the retrieved approach rule as 'slowly from the side', 'side approach', or equivalent. Mentioning only that Koro is beside the food bowl, or mentioning only short clear signals, is not sufficient."
  }

  @ criteria[] {
    name = "no-internal-detail-leak"
    weight = 1
    pass-score = 0.95
    description = "The cognition entry does not expose internal implementation details such as module names, memo plumbing, prompts, rubrics, or hidden evaluation mechanics."
  }
}
