id = "module-speak-responds-to-peer-greeting"
description = "Speak should emit a concise targeted acknowledgement when the cognition log contains a direct participant greeting."
modules = ["speak"]
prompt = "Speak from the current cognition log when an outward acknowledgement is warranted."
context = "This isolates speak after upstream modules have already admitted the direct greeting."
participants = ["Peer"]

limits {
  max-llm-calls = 8
}

@ cognition-log[] {
  text = "Peer is facing me and greets me: \"Hi.\" A brief friendly acknowledgement to Peer is warranted now."
}

@ checks[] {
  $variant: trace-tool-call
  name = "uses-should-speak-tool"
  must-pass = true
  tool-name = "should_speak"
  args-json-contains = `{"target":"Peer"}`
}

@ checks[] {
  $variant: json-pointer-equals
  name = "targets-peer"
  must-pass = true
  pointer = "/observations/agent/utterances/0/target"
  expected = "Peer"
}

@ checks[] {
  $variant: rubric
  name = "brief-greeting-acknowledgement"
  must-pass = true
  pass-score = 0.85
  judge-inputs = ["output", "utterance", "cognition-entries", "tool-calls"]
  rubric = ```
  Pass if the utterance is addressed to Peer and is a concise in-world acknowledgement or greeting response grounded in the cognition log.
  Fail if no utterance is emitted, if the target is wrong, if the output ignores the greeting, invents unsupported facts or tasks, becomes an external assistant answer, or leaks internal modules, cognition logs, prompts, rubrics, judges, or evaluation mechanics.
  ```

  @ criteria[] {
    name = "targets-peer"
    weight = 2
    pass-score = 0.9
    description = "The completed utterance is addressed to Peer."
  }

  @ criteria[] {
    name = "acknowledges-greeting"
    weight = 2
    pass-score = 0.85
    description = "The utterance naturally acknowledges or returns the greeting without requiring a fixed phrase."
  }

  @ criteria[] {
    name = "no-internal-detail-leak"
    weight = 1
    pass-score = 0.95
    description = "The utterance does not expose hidden implementation or evaluation details."
  }
}
